{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",         // scripts run directly with ts-node, CommonJS is simplest
        "rootDir": "./",
        "outDir": "./dist/scripts",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node"]             // gives access to process, __dirname, Buffer, etc.
    },
    "include": [
        "scripts/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
