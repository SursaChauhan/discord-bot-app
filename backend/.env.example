# Backend Environment Variables
# Copy this file to .env and fill in all values.
# Never commit the real .env file — it contains secrets.

# ─── Discord ──────────────────────────────────────────────────────────────────

# Your Discord Application ID (found in Developer Portal → General Information)
DISCORD_APP_ID=

# Ed25519 public key used to verify incoming interaction signatures
# (found in Developer Portal → General Information → Public Key)
DISCORD_PUBLIC_KEY=

# Bot token for authenticating API calls (sending replies, posting to channels)
# Starts with a long alphanumeric string — keep this secret
DISCORD_BOT_TOKEN=

# Your Discord server (guild) ID — enable Developer Mode in Discord to copy it
DISCORD_GUILD_ID=

# ─── Supabase ─────────────────────────────────────────────────────────────────

# Your Supabase project URL (found in Project Settings → API)
SUPABASE_URL=

# Service role key — has full DB access, never expose to the frontend
# (found in Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Auth ─────────────────────────────────────────────────────────────────────

# Secret used to sign admin JWT tokens — use a long random string
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# ─── AI (optional) ────────────────────────────────────────────────────────────

# Google Gemini API key — free tier via Google AI Studio (https://aistudio.google.com)
# Leave empty to disable AI summarisation
GEMINI_API_KEY=

# ─── Slack (optional) ─────────────────────────────────────────────────────────

# Default Slack Incoming Webhook URL for mirroring bot events
# Can also be configured per-server from the admin dashboard
# Leave empty if you don't need Slack mirroring
SLACK_WEBHOOK_URL=

# ─── Server ───────────────────────────────────────────────────────────────────

# Port the Hono HTTP server listens on (default: 3000)
PORT=3000

# Frontend origin — used for CORS headers in production
FRONTEND_URL=http://localhost:5173
